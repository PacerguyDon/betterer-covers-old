{
  "version": 2,
  "rewrites": [
    {
      "source": "/media.trakt.tv/:path*",
      "destination": "/api/trakt/poster?src=https://trakt.tv*"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
