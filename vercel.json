{
  "version": 2,
  "redirects": [
    {
      "source": "/media.trakt.tv/:path*",
      "destination": "https://trakt.tv*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
