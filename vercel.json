{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/trakt/poster",
      "destination": "/api/index.js"
    },
    {
      "source": "/media.trakt.tv/(.*)",
      "destination": "/api/trakt/poster?src=https://trakt.tv"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
