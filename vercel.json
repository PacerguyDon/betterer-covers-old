{
  "version": 2,
  "functions": {
    "api/*.mjs": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/media.trakt.tv/(.*)",
      "destination": "/api/trakt/poster?src=https://trakt.tv"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
